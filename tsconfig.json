{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-runtime/types/**/*.ts",
    ".next-runtime/dev/types/**/*.ts",
    "**/*.mts",
    ".next-preview/types/**/*.ts",
    ".next-preview/dev/types/**/*.ts",
    ".next-preview-invite/types/**/*.ts",
    ".next-preview-invite/dev/types/**/*.ts",
    ".next-preview-perm/types/**/*.ts",
    ".next-preview-perm/dev/types/**/*.ts",
    ".next-preview-prop/types/**/*.ts",
    ".next-preview-prop/dev/types/**/*.ts",
    ".next-preview-billing/types/**/*.ts",
    ".next-preview-billing/dev/types/**/*.ts",
    ".next-preview-prop2/types/**/*.ts",
    ".next-preview-prop2/dev/types/**/*.ts",
    ".next-preview-tweaks/types/**/*.ts",
    ".next-preview-tweaks/dev/types/**/*.ts",
    ".next-preview-act/types/**/*.ts",
    ".next-preview-act/dev/types/**/*.ts",
    ".next-preview-pill/types/**/*.ts",
    ".next-preview-pill/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/creed-cli"
  ]
}
